{
  "name": "@voxxo/atlas",
  "version": "1.0.0",
  "type": "module",
  "description": "Deterministic, local-first code intelligence for agents, CLIs, and MCP clients.",
  "license": "MIT",
  "author": "Jonah",
  "homepage": "https://github.com/dogtorjonah/atlas-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dogtorjonah/atlas-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/dogtorjonah/atlas-mcp-server/issues"
  },
  "keywords": [
    "code-intelligence",
    "mcp",
    "model-context-protocol",
    "sqlite",
    "static-analysis"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "migrations/*.sql",
    "README.md",
    "ARCHITECTURE.md",
    "PUBLIC_API.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "UPGRADING.md",
    "LICENSE",
    "RELICENSE_AUDIT.md",
    "THIRD_PARTY_NOTICES.md",
    "docs",
    "examples",
    "sbom.cdx.json"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./db": "./dist/db.js",
    "./types": "./dist/types.js",
    "./paths": "./dist/paths.js",
    "./pipeline": "./dist/pipeline/index.js",
    "./persistence": "./dist/persistence/index.js",
    "./indexing": "./dist/indexing/index.js",
    "./service": "./dist/service/index.js",
    "./writeback": "./dist/writeback/index.js",
    "./admin": "./dist/admin/index.js",
    "./embedding": "./dist/embedding/index.js",
    "./mcp": "./dist/mcp/index.js",
    "./node": "./dist/node/index.js"
  },
  "bin": {
    "atlas": "./dist/server.js",
    "atlas-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:adapter": "tsc -p packages/context-warp-adapter/tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "init": "tsx src/server.ts init",
    "start": "node dist/server.js",
    "test": "node --import tsx --test --test-concurrency=1 src/__tests__/*.test.ts",
    "test:adapter": "node --import tsx --test packages/context-warp-adapter/test/*.test.ts",
    "test:adapter:package": "node scripts/adapter-smoke.mjs",
    "test:performance": "node scripts/performance-gates.mjs",
    "test:package": "node scripts/package-smoke.mjs",
    "test:release": "node scripts/release-regression.mjs",
    "sbom": "node scripts/generate-sbom.mjs",
    "sbom:check": "node scripts/generate-sbom.mjs --check",
    "prepack": "npm run sbom:check && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.10.0",
    "sqlite-vec": "^0.1.6",
    "tree-sitter": "^0.25.0",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-java": "^0.23.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.23.0",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
