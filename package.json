{
  "name": "@voxxo/atlas",
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone MCP server for the Voxxo codebase atlas.",
  "license": "AGPL-3.0-only",
  "main": "dist/index.js",
  "files": [
    "dist",
    "migrations/*.sql",
    "README.md",
    "ARCHITECTURE.md",
    "PUBLIC_API.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./db": "./dist/db.js",
    "./types": "./dist/types.js",
    "./paths": "./dist/paths.js",
    "./pipeline": "./dist/pipeline/index.js",
    "./persistence": "./dist/persistence/index.js",
    "./indexing": "./dist/indexing/index.js"
  },
  "bin": {
    "atlas": "./dist/server.js",
    "atlas-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "init": "tsx src/server.ts init",
    "start": "node dist/server.js",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "test:package": "node scripts/package-smoke.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.10.0",
    "sqlite-vec": "^0.1.6",
    "tree-sitter": "^0.25.0",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-java": "^0.23.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.23.0",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
