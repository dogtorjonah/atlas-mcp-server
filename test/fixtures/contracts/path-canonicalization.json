    },
    {
      "name": "invalid workspace",
      "context": "invalid-workspace",
      "input": "src/index.ts",
      "expected": {
        "ok": false,
        "code": "INVALID_WORKSPACE",
        "message": "Workspace must be a canonical non-empty slug."
