    {
      "name": "noncanonical mapping",
      "context": "invalid-mapping",
      "input": "src/link/file.ts",
      "expected": {
        "ok": false,
        "code": "INVALID_MAPPING",
        "message": "Path aliases and redirects must be canonical repository-relative paths."
