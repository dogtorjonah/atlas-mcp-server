        "aliases": [
          "src/linked-math/add.ts"
        ],
        "resolvedSymlink": true,
        "redirected": false
      }
    },
    {
      "name": "historical rename alias",
      "context": "posix",
      "input": "src/rename/old-name.ts",
      "expected": {
        "ok": true,
        "workspace": "fixture-small",
        "path": "src/rename/new-name.ts",
